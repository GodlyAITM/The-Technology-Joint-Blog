---

---

<div class="search">
    <input
        id="search-input"
        type="search"
        placeholder="Search articles..."
        autocomplete="off"
    />

    <div id="search-results"></div>
</div>

<script type="module">
    const input = document.querySelector("#search-input");
    const results = document.querySelector("#search-results");
    let articles = [];

    async function loadIndex() {
        try {
            const response = await fetch("/search-index.json");
            articles = await response.json();
        } catch (error) {
            console.error("Failed to load search index", error);
        }
    }

    loadIndex();

    input?.addEventListener("input", (event) => {
        const value = event.target.value.toLowerCase().trim();

        if (!value) {
            results.innerHTML = "";
            return;
        }

        const matches = articles.filter(
            (article) =>
                article.title.toLowerCase().includes(value) ||
                article.description.toLowerCase().includes(value) ||
                article.category.toLowerCase().includes(value) ||
                article.author.toLowerCase().includes(value) ||
                article.tags.join(" ").toLowerCase().includes(value),
        );

        results.innerHTML = matches
            .map(
                (article) =>
                    `<a href="${article.url}" class="result">
                        <h3>${article.title}</h3>
                        <p>${article.description}</p>
                    </a>`,
            )
            .join("");
    });
</script>

<style>
    .search {
        max-width: 720px;

        margin: auto;
    }

    .search input {
        width: 100%;

        padding: 1rem;

        border-radius: 10px;

        border: 1px solid var(--color-border);

        background: var(--color-surface);

        color: var(--color-text);

        font-size: 1rem;
    }

    #search-results {
        margin-top: 2rem;

        display: grid;

        gap: 1rem;
    }

    .result {
        display: block;

        padding: 1rem;

        border: 1px solid var(--color-border);

        border-radius: 10px;

        background: var(--color-surface);

        text-decoration: none;

        color: inherit;

        transition: 0.2s;
    }

    .result:hover {
        transform: translateY(-2px);
    }

    .result h3 {
        margin-bottom: 0.5rem;
    }

    .result p {
        color: var(--color-muted);
    }
</style>
