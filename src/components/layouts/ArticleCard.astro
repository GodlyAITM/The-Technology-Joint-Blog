---
import type { CollectionEntry } from "astro:content";

interface Props {
    article?: CollectionEntry<"articles">;
    title?: string;
    excerpt?: string;
    category?: string;
    href?: string;
    author?: string;
    pubDate?: Date | string;
}

const {
    article,
    title,
    excerpt,
    category,
    href = "#",
    author,
    pubDate,
} = Astro.props;

const articleData = article?.data;
const cardTitle = articleData?.title ?? title ?? "Untitled";
const cardDescription = articleData?.description ?? excerpt ?? "";
const cardCategory = articleData?.category ?? category ?? "";
const cardAuthor = articleData?.author ?? author ?? "";
const cardPubDate = articleData?.pubDate ?? pubDate;
const articleSlug = article ? article.id.replace(/\.md$/, "") : undefined;
const cardHref = articleSlug ? `/articles/${articleSlug}` : href;
const formattedDate = cardPubDate
    ? typeof cardPubDate === "string"
        ? cardPubDate
        : cardPubDate.toLocaleDateString()
    : "";
---

    {articleData?.heroImage && (
        <figure class="card-image">
            <img
                src={articleData.heroImage}
                alt={articleData.featuredImageAlt ?? cardTitle}
                loading="lazy"
            />
        </figure>
    )}
<article class="card">
    {cardCategory && <div class="badge">{cardCategory}</div>}

    <h2>
        <a href={cardHref}>
            {cardTitle}
        </a>
    </h2>

    <p>
        {cardDescription}
    </p>

    {
        (cardAuthor || formattedDate) && (
            <div class="meta">
                {cardAuthor && <span>{cardAuthor}</span>}

                {cardAuthor && formattedDate && <span>•</span>}

                {formattedDate && <span>{formattedDate}</span>}
            </div>
        )
    }

    <a href={cardHref} class="read-more"> Read Article → </a>
</article>

<style>
    .card {
        background: white;

        border: 1px solid var(--color-border);

        border-radius: 20px;

        padding: 2rem;

        transition: 0.25s;

        display: flex;

        flex-direction: column;

        gap: 1rem;

        height: 100%;
    }

    .card:hover {
        transform: translateY(-6px);

        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.08);
    }

    .badge {
        display: inline-block;

        width: fit-content;

        padding: 0.35rem 0.9rem;

        border-radius: 999px;

        background: #dbeafe;

        color: #2563eb;

        font-size: 0.8rem;

        font-weight: 700;

        text-transform: uppercase;
    }

    .card h2 {
        margin: 0;
    }

    .card h2 a {
            background: var(--color-surface);

        text-decoration: none;
    }

    .card p {
        line-height: 1.8;

        color: var(--color-muted);

        flex-grow: 1;
    }
            transform: translateY(-6px);
            box-shadow: var(--shadow-md);
            border-color: rgba(37, 99, 235, 0.2);
        display: flex;

        .card-image {
            margin: 0 -2rem 1.5rem;
        }

        .card-image img {
            width: 100%;
            display: block;
            object-fit: cover;
            aspect-ratio: 16 / 10;
            border-radius: 20px;
        }

        gap: 0.75rem;

        font-size: 0.9rem;

        opacity: 0.75;

        flex-wrap: wrap;
    }

    .read-more {
        margin-top: auto;

        font-weight: 700;

        text-decoration: none;

        color: #2563eb;
    }
</style>
