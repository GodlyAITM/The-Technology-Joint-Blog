---
interface Props {
    title: string;

    excerpt: string;

    category: string;

    href: string;
}

const { title, excerpt, category, href } = Astro.props;
---

<a class="card" href={href}>
    <span class="category">
        {category}
    </span>

    <h3>
        {title}
    </h3>

    <p>
        {excerpt}
    </p>

    <span class="readmore"> Read Article → </span>
</a>

<style>
    .card {
        display: block;

        padding: 2rem;

        border-radius: 18px;

        background: white;

        border: 1px solid var(--color-border);

        text-decoration: none;

        transition: 0.25s;
    }

    .card:hover {
        transform: translateY(-4px);

        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.08);
    }

    .category {
        display: inline-block;

        margin-bottom: 1rem;

        font-size: 0.8rem;

        font-weight: 700;

        color: var(--color-primary);

        text-transform: uppercase;
    }

    h3 {
        margin-bottom: 1rem;
    }

    p {
        color: var(--color-muted);

        margin-bottom: 2rem;
    }

    .readmore {
        font-weight: 700;
    }
</style>
