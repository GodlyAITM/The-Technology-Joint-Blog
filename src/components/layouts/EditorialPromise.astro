---
import SectionHeading from "./SectionHeading.astro";
---

<section class="editorial-promise">
    <div class="container">
        <SectionHeading
            eyebrow="Editorial Standards"
            title="Technology Journalism You Can Trust"
            description="Every article published on The Technology Joint is created with one goal: helping readers make better technology decisions."
        />

        <div class="promise-grid">
            <article class="promise-card">
                <h3>Research First</h3>

                <p>
                    We prioritize accuracy over speed. Every guide is based on
                    careful research, trusted sources and practical testing.
                </p>
            </article>

            <article class="promise-card">
                <h3>Practical Advice</h3>

                <p>
                    We explain technology in plain language and focus on
                    solutions you can actually apply.
                </p>
            </article>

            <article class="promise-card">
                <h3>Independent Reviews</h3>

                <p>
                    Recommendations are made because they provide value—not
                    because they generate commissions.
                </p>
            </article>

            <article class="promise-card">
                <h3>Security Conscious</h3>

                <p>
                    Cybersecurity and digital privacy are integrated into our
                    recommendations wherever they matter.
                </p>
            </article>
        </div>
    </div>
</section>

<style>
    .editorial-promise {
        padding: 6rem 0;

        background: #ffffff;
    }

    .promise-grid {
        display: grid;

        grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));

        gap: 2rem;

        margin-top: 3rem;
    }

    .promise-card {
        padding: 2rem;

        border: 1px solid var(--color-border);

        border-radius: 18px;

        background: #fff;

        transition: 0.25s;
    }

    .promise-card:hover {
        transform: translateY(-4px);

        box-shadow: 0 18px 35px rgba(0, 0, 0, 0.06);
    }

    .promise-card h3 {
        margin-bottom: 1rem;
    }

    .promise-card p {
        line-height: 1.8;

        color: var(--color-muted);
    }
</style>
