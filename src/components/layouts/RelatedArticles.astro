---
import ArticleCard from "./ArticleCard.astro";

import { getRelatedArticles, type Article } from "../../lib/articles";

interface Props {
    currentArticle: Article;
    limit?: number;
}

const { currentArticle, limit = 3 } = Astro.props;

const relatedArticles = await getRelatedArticles(currentArticle, limit);
---

{
    relatedArticles.length > 0 && (
        <section class="related">
            <div class="section-header">
                <h2>Continue Reading</h2>

                <p>More articles you may find useful.</p>
            </div>

            <div class="related-grid">
                {relatedArticles.map((article) => (
                    <ArticleCard article={article} />
                ))}
            </div>
        </section>
    )
}

<style>
    .related {
        margin-top: 5rem;

        padding-top: 4rem;

        border-top: 1px solid #e5e7eb;
    }

    .section-header {
        margin-bottom: 2rem;
    }

    .section-header h2 {
        margin: 0;

        font-size: 2rem;
    }

    .section-header p {
        margin-top: 0.75rem;

        color: var(--color-muted);
    }

    .related-grid {
        display: grid;

        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));

        gap: 2rem;
    }

    @media (max-width: 768px) {
        .related {
            margin-top: 4rem;

            padding-top: 3rem;
        }
    }
</style>
