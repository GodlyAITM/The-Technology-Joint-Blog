---
interface Props {
    author: string;
}

const { author } = Astro.props;
---

<section class="author-box">
    <div class="author-content">
        <div class="avatar">IA</div>

        <div>
            <p class="small">Written by</p>

            <h3>
                {author}
            </h3>

            <p>
                Founder & Editor of The Technology Joint. Israel writes
                practical guides on technology, cybersecurity, software, SEO and
                digital growth with a focus on helping people make better
                technology decisions.
            </p>

            <a href="/about"> Learn more → </a>
        </div>
    </div>
</section>

<style>
    .author-box {
        margin-top: 5rem;

        padding: 2rem;

        border: 1px solid var(--color-border);

        border-radius: 20px;

        background: #f8fafc;
    }

    .author-content {
        display: flex;

        gap: 2rem;

        align-items: flex-start;
    }

    .avatar {
        width: 72px;

        height: 72px;

        border-radius: 50%;

        background: #2563eb;

        color: white;

        display: flex;

        align-items: center;

        justify-content: center;

        font-weight: 700;

        font-size: 1.25rem;

        flex-shrink: 0;
    }

    .small {
        font-size: 0.85rem;

        text-transform: uppercase;

        letter-spacing: 0.08em;

        opacity: 0.7;

        margin-bottom: 0.5rem;
    }

    .author-box h3 {
        margin-bottom: 0.75rem;
    }

    .author-box p {
        line-height: 1.8;
    }

    .author-box a {
        display: inline-block;

        margin-top: 1rem;

        font-weight: 700;

        text-decoration: none;

        color: #2563eb;
    }

    @media (max-width: 768px) {
        .author-content {
            flex-direction: column;
        }
    }
</style>
