---
import { getAuthor } from "../../lib/author";

interface Props {
    author: string;
}

const { author } = Astro.props;
const authorData = getAuthor(author);
---

<section class="author-box">
    <div class="author-content">
        <div class="avatar">
            <img src={authorData.avatar} alt={authorData.name} loading="lazy" />
        </div>

        <div>
            <p class="small">Written by</p>

            <h3>
                {authorData.name}
            </h3>

            <p>
                {authorData.title}. {authorData.bio}
            </p>

            <a href="/about"> Learn more → </a>
        </div>
    </div>
</section>

<style>
    .author-box {
        margin-top: 5rem;

        padding: 2rem;

        border: 1px solid var(--color-border);

        border-radius: 20px;

        background: #f8fafc;
    }

    .author-content {
        display: flex;

        gap: 2rem;

        align-items: flex-start;
    }

    .avatar {
        width: 72px;

        height: 72px;

        border-radius: 50%;

        background: #2563eb;

        color: white;

        display: flex;

        align-items: center;

        justify-content: center;

        font-weight: 700;

        font-size: 1.25rem;

        flex-shrink: 0;

        overflow: hidden;
    }

    .avatar img {
        width: 100%;

        height: 100%;

        object-fit: cover;

        display: block;
    }

    .small {
        font-size: 0.85rem;

        text-transform: uppercase;

        letter-spacing: 0.08em;

        opacity: 0.7;

        margin-bottom: 0.5rem;
    }

    .author-box h3 {
        margin-bottom: 0.75rem;
    }

    .author-box p {
        line-height: 1.8;
    }

    .author-box a {
        display: inline-block;

        margin-top: 1rem;

        font-weight: 700;

        text-decoration: none;

        color: #2563eb;
    }

    @media (max-width: 768px) {
        .author-content {
            flex-direction: column;
        }
    }
</style>
