---

<section class="newsletter">
    <div class="container">
        <div class="box">
            <p class="eyebrow">JOIN THE COMMUNITY</p>

            <h2>Stay Ahead of Technology.</h2>

            <p>
                Receive practical technology guides, cybersecurity advice, AI
                updates and software recommendations directly from The
                Technology Joint.
            </p>

            <form>
                <input type="email" placeholder="Enter your email address" />

                <button> Subscribe </button>
            </form>

            <p class="small">No spam. Only valuable technology insights.</p>
        </div>
    </div>
</section>

<style>
    .newsletter {
        padding: 6rem 0;
    }

    .box {
        padding: 4rem;

        background: #0f172a;

        color: white;

        border-radius: 24px;

        text-align: center;
    }

    .eyebrow {
        letter-spacing: 0.1em;

        font-weight: 700;

        opacity: 0.8;

        margin-bottom: 1rem;
    }

    .box h2 {
        margin-bottom: 1rem;
    }

    .box p {
        max-width: 680px;

        margin: 0 auto;

        line-height: 1.8;
    }

    form {
        display: flex;

        gap: 1rem;

        justify-content: center;

        margin: 2rem auto;

        max-width: 650px;
    }

    input {
        flex: 1;

        padding: 1rem;

        border: none;

        border-radius: 999px;
    }

    button {
        padding: 1rem 2rem;

        border: none;

        border-radius: 999px;

        background: #2563eb;

        color: white;

        font-weight: 700;

        cursor: pointer;
    }

    .small {
        opacity: 0.7;

        font-size: 0.9rem;
    }

    @media (max-width: 768px) {
        form {
            flex-direction: column;
        }
    }
</style>
