---
import SectionHeading from "./SectionHeading.astro";
import { SITE } from "../../config/site";
---

<section class="founder">
    <div class="container">
        <SectionHeading
            eyebrow="Founder"
            title="Meet the person behind the publication"
            description="Technology journalism backed by practical SEO experience and long-form clarity."
        />

        <div class="content">
            <img src={SITE.founderImage} alt={SITE.author} />

            <div class="copy">
                <h3>{SITE.author}</h3>

                <p>
                    The Technology Joint was founded to make technology easier
                    to understand. Instead of chasing headlines, we focus on
                    practical guides, trustworthy reviews, cybersecurity
                    awareness and search-first content that genuinely helps
                    readers.
                </p>

                <p>
                    Alongside publishing technology content, I help businesses
                    improve their visibility through technical SEO, content
                    strategy and long-form articles that rank.
                </p>

                <a class="button" href="/about"> Learn More </a>
            </div>
        </div>
    </div>
</section>

<style>
    .founder {
        padding: 5rem 0;
    }

    .content {
        display: grid;
        grid-template-columns: 280px minmax(0, 1fr);
        gap: 3rem;
        align-items: center;
    }

    .content img {
        width: 100%;
        border-radius: 24px;
        object-fit: cover;
        box-shadow: var(--shadow-md);
    }

    .copy h3 {
        margin-top: 0;
        margin-bottom: 1.25rem;
    }

    .button {
        display: inline-block;
        margin-top: 2rem;
        padding: 0.95rem 1.75rem;
        background: var(--color-primary);
        color: white;
        border-radius: 999px;
        text-decoration: none;
        transition: background var(--transition);
    }

    .button:hover {
        background: var(--color-primary-dark);
    }

    @media (max-width: 900px) {
        .content {
            grid-template-columns: 1fr;
        }
    }
</style>
