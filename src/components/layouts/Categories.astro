---
import SectionHeading from "./SectionHeading.astro";
import { getAllCategories } from "../../lib/articles";
import { getCategoryUrl } from "../../lib/seo";

const categories = await getAllCategories();
---

<section class="categories-section">
    <div class="container">
        <SectionHeading
            eyebrow="Topics"
            title="Browse by category"
            description="Each article is automatically grouped by category. Add category tags in frontmatter and the system will sort it for you."
        />

        <div class="category-list">
            {
                categories.map((category) => (
                    <a href={getCategoryUrl(category)}>{category}</a>
                ))
            }
        </div>
    </div>
</section>

<style>
    .categories-section {
        padding: 6rem 0;
        background: var(--color-surface);
        border-top: 1px solid var(--color-border);
    }

    .category-list {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        gap: 1rem;
        margin-top: 2rem;
    }

    .category-list a {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 1rem 1.25rem;
        border-radius: 999px;
        background: var(--color-surface-alt);
        color: var(--color-primary);
        font-weight: 700;
        text-decoration: none;
        border: 1px solid transparent;
        transition:
            border-color var(--transition),
            background var(--transition);
    }

    .category-list a:hover {
        border-color: var(--color-primary);
        background: rgba(37, 99, 235, 0.08);
    }
</style>
