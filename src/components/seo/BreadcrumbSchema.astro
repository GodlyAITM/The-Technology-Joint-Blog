---
import { SITE } from "../../config/site";

interface Props {
    category: string;
    title: string;
    url: string;
}

const { category, title, url } = Astro.props;

const schema = {
    "@context": "https://schema.org",

    "@type": "BreadcrumbList",

    itemListElement: [
        {
            "@type": "ListItem",

            position: 1,

            name: "Home",

            item: SITE.url,
        },

        {
            "@type": "ListItem",

            position: 2,

            name: category,

            item: `${SITE.url}/categories/${category.toLowerCase()}`,
        },

        {
            "@type": "ListItem",

            position: 3,

            name: title,

            item: url,
        },
    ],
};
---

<script type="application/ld+json" set:html={JSON.stringify(schema)} />
