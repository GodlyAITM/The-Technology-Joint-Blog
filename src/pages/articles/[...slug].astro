---
import { getCollection, render, type CollectionEntry } from "astro:content";

import BaseLayout from "../../layouts/BaseLayout.astro";

import Header from "../../components/layouts/Header.astro";
import Footer from "../../components/layouts/Footer.astro";

import HeroImage from "../../components/layouts/HeroImage.astro";
import AuthorBox from "../../components/layouts/AuthorBox.astro";
import RelatedArticles from "../../components/layouts/RelatedArticles.astro";
import NewsletterCTA from "../../components/layouts/NewsletterCTA.astro";

import ReadingProgress from "../../components/article/ReadingProgress.astro";
import ArticleMeta from "../../components/article/ArticleMeta.astro";
import TableOfContents from "../../components/article/TableOfContents.astro";

interface Props {
    article: CollectionEntry<"articles">;
}

export async function getStaticPaths() {
    const articles = await getCollection(
        "articles",
        (article: CollectionEntry<"articles">) => !article.data.draft,
    );

    return articles.map((article) => ({
        params: {
            slug: article.id,
        },
        props: {
            article,
        },
    }));
}

const { article } = Astro.props as Props;

const { Content, headings } = await render(article);

const rawBody = (article.body ?? "").toString();

const words = rawBody
    .replace(/[#>*`\[\]\(\)]/g, "")
    .split(/\s+/)
    .filter(Boolean).length;

const readingTime = Math.max(1, Math.ceil(words / 200));
---

<BaseLayout
    title={article.data.seoTitle ?? article.data.title}
    description={article.data.seoDescription ?? article.data.description}
>
    <ReadingProgress />

    <Header />

    <main>
        <section class="article-header">
            <div class="container">
                <p class="category">
                    {article.data.category}
                </p>

                <h1>
                    {article.data.title}
                </h1>

                <p class="description">
                    {article.data.description}
                </p>

                <ArticleMeta
                    author={article.data.author}
                    published={article.data.pubDate}
                    updated={article.data.updatedDate}
                    readingTime={readingTime}
                />

                <HeroImage
                    src={article.data.heroImage}
                    alt={article.data.featuredImageAlt}
                />
            </div>
        </section>

        <section class="article-content">
            <div class="container article-grid">
                <TableOfContents headings={headings} />

                <article class="prose">
                    <Content />

                    <AuthorBox author={article.data.author} />

                    <RelatedArticles currentArticle={article} />

                    <NewsletterCTA />
                </article>
            </div>
        </section>
    </main>

    <Footer />
</BaseLayout>

<style>
    .article-header {
        padding: 5rem 0 2rem;
    }

    .category {
        display: inline-block;

        background: #dbeafe;

        color: #2563eb;

        padding: 0.45rem 1rem;

        border-radius: 999px;

        font-size: 0.85rem;

        font-weight: 700;

        letter-spacing: 0.05em;

        text-transform: uppercase;

        margin-bottom: 1rem;
    }

    .description {
        max-width: 760px;

        margin-top: 1rem;

        font-size: 1.15rem;

        line-height: 1.8;

        color: var(--color-muted);
    }

    .article-content {
        padding: 4rem 0 6rem;
    }

    .article-grid {
        display: grid;

        grid-template-columns: 280px minmax(0, 760px);

        gap: 4rem;

        align-items: start;
    }

    .prose {
        width: 100%;
    }

    .prose h2 {
        margin-top: 3.5rem;

        margin-bottom: 1rem;

        scroll-margin-top: 120px;
    }

    .prose h3 {
        margin-top: 2.5rem;

        margin-bottom: 0.75rem;

        scroll-margin-top: 120px;
    }

    .prose p {
        margin-bottom: 1.7rem;

        line-height: 1.9;
    }

    .prose ul,
    .prose ol {
        margin: 2rem 0;

        padding-left: 1.5rem;

        line-height: 1.9;
    }

    .prose li {
        margin-bottom: 0.8rem;
    }

    .prose img {
        width: 100%;

        border-radius: 18px;

        margin: 3rem 0;
    }

    .prose blockquote {
        margin: 2.5rem 0;

        padding: 1.5rem;

        border-left: 4px solid var(--color-primary);

        background: #f8fafc;

        border-radius: 10px;

        font-style: italic;
    }

    .prose code {
        padding: 0.2rem 0.45rem;

        border-radius: 6px;

        background: #eef2ff;

        font-size: 0.92em;
    }

    .prose pre {
        overflow: auto;

        padding: 1.5rem;

        border-radius: 14px;

        margin: 2rem 0;
    }

    .prose table {
        width: 100%;

        border-collapse: collapse;

        margin: 2.5rem 0;
    }

    .prose th,
    .prose td {
        padding: 1rem;

        border: 1px solid #e5e7eb;

        text-align: left;
    }

    .prose th {
        background: #f8fafc;
    }

    @media (max-width: 960px) {
        .article-grid {
            grid-template-columns: 1fr;

            gap: 2rem;
        }
    }
</style>
