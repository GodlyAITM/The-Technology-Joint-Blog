---
import { getCollection, render, type CollectionEntry } from "astro:content";

import BaseLayout from "../../layouts/BaseLayout.astro";

import Header from "../../components/layouts/Header.astro";
import Footer from "../../components/layouts/Footer.astro";

import HeroImage from "../../components/layouts/HeroImage.astro";
import AuthorBox from "../../components/layouts/AuthorBox.astro";
import RelatedArticles from "../../components/layouts/RelatedArticles.astro";
import NewsletterCTA from "../../components/layouts/NewsletterCTA.astro";

import ReadingProgress from "../../components/article/ReadingProgress.astro";
import ArticleMeta from "../../components/article/ArticleMeta.astro";
import TableOfContents from "../../components/article/TableOfContents.astro";
import ShareButtons from "../../components/article/ShareButtons.astro";

import ArticleSchema from "../../components/seo/ArticleSchema.astro";
import BreadcrumbSchema from "../../components/seo/BreadcrumbSchema.astro";

import {
    buildPageTitle,
    buildMetaDescription,
    getArticleUrl,
    getCanonicalUrl,
    getImageUrl,
} from "../../lib/seo";

interface Props {
    article: CollectionEntry<"articles">;
}

export async function getStaticPaths() {
    const articles = await getCollection("articles", ({ data }) => !data.draft);

    return articles.map((article) => ({
        params: {
            slug: article.id,
        },

        props: {
            article,
        },
    }));
}

const { article } = Astro.props as Props;

const { Content, headings } = await render(article);

const rawBody = (article.body ?? "").toString();

const words = rawBody
    .replace(/[#>*`\[\]\(\)]/g, "")
    .split(/\s+/)
    .filter(Boolean).length;

const readingTime = Math.max(1, Math.ceil(words / 200));

const articleUrl = getArticleUrl(article.id);

const canonicalUrl = getCanonicalUrl({
    canonical: article.data.canonicalURL ?? articleUrl,
});

const heroImage = getImageUrl(article.data.heroImage);

const pageTitle = buildPageTitle(article.data.seoTitle ?? article.data.title);

const pageDescription = buildMetaDescription(
    article.data.seoDescription ?? article.data.description,
);
---

<BaseLayout
    title={pageTitle}
    description={pageDescription}
    canonical={canonicalUrl}
    image={heroImage}
>
    <Fragment slot="head">
        <ArticleSchema
            title={article.data.title}
            description={article.data.description}
            author={article.data.author}
            published={article.data.pubDate}
            updated={article.data.updatedDate}
            image={article.data.heroImage}
            canonical={canonicalUrl}
        />

        <BreadcrumbSchema
            category={article.data.category}
            title={article.data.title}
            url={canonicalUrl}
        />
    </Fragment>

    <ReadingProgress />

    <Header />

    <main>
        <section class="article-header">
            <div class="container">
                <p class="category">
                    {article.data.category}
                </p>

                <h1>
                    {article.data.title}
                </h1>

                <p class="description">
                    {article.data.description}
                </p>

                <ArticleMeta
                    author={article.data.author}
                    published={article.data.pubDate}
                    updated={article.data.updatedDate}
                    readingTime={readingTime}
                />

                <HeroImage
                    src={article.data.heroImage}
                    alt={article.data.featuredImageAlt}
                />
            </div>
        </section>

        <section class="article-content">
            <div class="container article-grid">
                <TableOfContents headings={headings} />

                <article class="prose">
                    <Content />

                    <ShareButtons
                        title={article.data.title}
                        url={canonicalUrl}
                    />

                    <AuthorBox author={article.data.author} />

                    <RelatedArticles currentArticle={article} />

                    <NewsletterCTA />
                </article>
            </div>
        </section>
    </main>

    <Footer />
</BaseLayout>

<style>
    .article-header {
        padding: 5rem 0 2rem;
    }

    .category {
        display: inline-block;

        margin-bottom: 1rem;

        padding: 0.45rem 1rem;

        border-radius: 999px;

        background: #dbeafe;

        color: #2563eb;

        font-size: 0.85rem;

        font-weight: 700;

        letter-spacing: 0.05em;

        text-transform: uppercase;
    }

    .article-header h1 {
        margin: 0;

        font-size: clamp(2.2rem, 5vw, 3.5rem);

        line-height: 1.15;

        max-width: 900px;
    }

    .description {
        max-width: 760px;

        margin-top: 1.25rem;

        font-size: 1.15rem;

        line-height: 1.85;

        color: var(--color-muted);
    }

    .article-content {
        padding: 4rem 0 6rem;
    }

    .article-grid {
        display: grid;

        grid-template-columns: 280px minmax(0, 760px);

        gap: 4rem;

        align-items: start;
    }

    .prose {
        width: 100%;
    }

    .prose h2 {
        margin-top: 4rem;

        margin-bottom: 1rem;

        scroll-margin-top: 120px;

        font-size: 2rem;

        line-height: 1.3;
    }

    .prose h3 {
        margin-top: 3rem;

        margin-bottom: 0.75rem;

        scroll-margin-top: 120px;

        font-size: 1.5rem;
    }

    .prose p {
        margin-bottom: 1.8rem;

        line-height: 1.9;
    }

    .prose strong {
        font-weight: 700;
    }

    .prose a {
        color: var(--color-primary);

        text-decoration: none;
    }

    .prose a:hover {
        text-decoration: underline;
    }

    .prose ul,
    .prose ol {
        margin: 2rem 0;

        padding-left: 1.5rem;

        line-height: 1.9;
    }

    .prose li {
        margin-bottom: 0.85rem;
    }

    .prose img {
        width: 100%;

        margin: 3rem 0;

        border-radius: 18px;
    }
    .prose figure {
        margin: 3rem 0;
    }

    .prose figcaption {
        margin-top: 0.75rem;

        text-align: center;

        font-size: 0.95rem;

        color: var(--color-muted);
    }

    .prose blockquote {
        margin: 3rem 0;

        padding: 2rem;

        border-left: 5px solid var(--color-primary);

        border-radius: 12px;

        background: #f8fafc;

        font-style: italic;
    }

    .prose blockquote p:last-child {
        margin-bottom: 0;
    }

    .prose hr {
        margin: 4rem 0;

        border: none;

        border-top: 1px solid #e5e7eb;
    }

    .prose code {
        padding: 0.2rem 0.45rem;

        border-radius: 6px;

        background: #eef2ff;

        font-size: 0.92em;

        font-family: Consolas, Monaco, "Courier New", monospace;
    }

    .prose pre {
    .prose pre {
        margin: 2.5rem 0;
        padding: 1.5rem;
        overflow: auto;
        border-radius: 16px;
        background: var(--code-bg);
    }

    .prose pre code {
        background: transparent;
        padding: 0;
        color: var(--code-text);
    }

    .prose table {
        width: 100%;

        margin: 3rem 0;

        border-collapse: collapse;

        overflow: hidden;

        border-radius: 14px;
    }

    .prose thead {
        background: #f8fafc;
    }

    .prose th {
        padding: 1rem;

        border: 1px solid #e5e7eb;

        text-align: left;

        font-weight: 700;
    }

    .prose td {
        padding: 1rem;

        border: 1px solid #e5e7eb;
    }

    .prose iframe {
        width: 100%;

        margin: 3rem 0;

        border: none;

        border-radius: 18px;

        aspect-ratio: 16 / 9;
    }

    .prose > :first-child {
        margin-top: 0;
    }

    .prose > :last-child {
        margin-bottom: 0;
    }

    .article-content .prose {
        min-width: 0;
    }
    @media (max-width: 1200px) {
        .article-grid {
            grid-template-columns: 240px minmax(0, 1fr);

            gap: 3rem;
        }
    }

    @media (max-width: 960px) {
        .article-header {
            padding: 4rem 0 2rem;
        }

        .article-grid {
            grid-template-columns: 1fr;

            gap: 2rem;
        }

        .prose {
            max-width: 100%;
        }
    }

    @media (max-width: 768px) {
        .article-header h1 {
            font-size: 2.25rem;
        }

        .description {
            font-size: 1.05rem;
        }

        .prose {
            font-size: 1rem;
        }

        .prose h2 {
            font-size: 1.75rem;
        }

        .prose h3 {
            font-size: 1.35rem;
        }

        .prose img {
            margin: 2rem 0;

            border-radius: 14px;
        }

        .prose blockquote {
            padding: 1.5rem;
        }

        .prose table {
            display: block;

            overflow-x: auto;

            white-space: nowrap;
        }
    }

    @media (max-width: 480px) {
        .category {
            font-size: 0.75rem;
        }

        .article-header h1 {
            font-size: 2rem;
        }

        .description {
            font-size: 1rem;
        }

        .prose h2 {
            font-size: 1.5rem;
        }

        .prose h3 {
            font-size: 1.25rem;
        }

        .prose {
            line-height: 1.85;
        }
    }
</style>
