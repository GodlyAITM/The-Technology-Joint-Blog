---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/layouts/Header.astro";
import Footer from "../../components/layouts/Footer.astro";
import ArticleCard from "../../components/layouts/ArticleCard.astro";
import { getAllTags, getArticlesByTag, type Article } from "../../lib/articles";
import { slugify } from "../../lib/seo";

interface Props {
    tag: string;
}

export async function getStaticPaths() {
    const tags = await getAllTags();

    return tags.map((t) => ({
        params: { tag: slugify(t) },
        props: { tag: t },
    }));
}

const { tag } = Astro.props as Props;

const articles = await getArticlesByTag(tag);
---

<BaseLayout
    title={`Tag: ${tag} | The Technology Joint`}
    description={`Articles tagged ${tag}`}
>
    <Header />

    <main>
        <section class="tag-page">
            <div class="container">
                <h1>Tag: {tag}</h1>

                <div class="grid">
                    {
                        articles.map((article: Article) => (
                            <ArticleCard article={article} />
                        ))
                    }
                </div>
            </div>
        </section>
    </main>

    <Footer />
</BaseLayout>

<style>
    .tag-page {
        padding: 4rem 0;
    }

    .grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
        gap: 1.5rem;
        margin-top: 2rem;
    }
</style>
