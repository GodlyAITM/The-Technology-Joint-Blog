---
import Navigation from "./Navigation.astro";
---

<header>
    <div class="container header">
        <a href="/" class="logo"> The Technology Joint </a>

        <Navigation />
    </div>
</header>

<style>
    header {
        background: white;

        border-bottom: 1px solid var(--color-border);

        position: sticky;

        top: 0;

        z-index: 999;
    }

    .header {
        display: flex;

        justify-content: space-between;

        align-items: center;

        padding: 1rem 0;
    }

    .logo {
        font-size: 1.5rem;

        font-weight: 800;
    }
</style>
