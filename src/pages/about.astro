---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/layouts/Header.astro";
import Footer from "../components/layouts/Footer.astro";
import PageHero from "../components/layouts/PageHero.astro";
---

<BaseLayout
  title="About The Technology Joint"
  description="Learn about The Technology Joint, our editorial mission and our founder."
>

  <Header />

  <main>

    <PageHero
      title="Technology Should Empower People"
      description="The Technology Joint is an independent technology publication dedicated to helping people make smarter technology decisions through practical, research-backed content."
    />

    <section class="about-section">

      <div class="container">

        <div class="content">

          <h2>Who We Are</h2>

          <p>
            The Technology Joint is a founder-led technology publication focused
            on creating trustworthy, practical and accessible technology
            journalism. Our goal is simple: remove the confusion from technology
            and help readers understand the tools shaping the modern world.
          </p>

          <p>
            Every article is written with long-term value in mind. Rather than
            chasing headlines, we focus on evergreen guides, honest reviews,
            cybersecurity awareness, software education and practical advice
            that remains useful long after publication.
          </p>

        </div>

      </div>

    </section>

    <section class="about-section alt">

      <div class="container">

        <div class="grid">

          <div class="card">

            <h3>Editorial Mission</h3>

            <p>
              Publish technology journalism that is accurate, practical and easy
              to understand.
            </p>

          </div>

          <div class="card">

            <h3>Editorial Standards</h3>

            <p>
              Every article is researched carefully and written to help readers
              make informed technology decisions—not simply generate clicks.
            </p>

          </div>

          <div class="card">

            <h3>Coverage</h3>

            <ul>

              <li>Cybersecurity</li>

              <li>Software & Artificial Intelligence</li>

              <li>Consumer Technology</li>

              <li>How-To Guides</li>

              <li>Search & Digital Growth</li>

            </ul>

          </div>

        </div>

      </div>

    </section>

    <section class="about-section">

      <div class="container">

        <div class="founder-box">

          <h2>Meet the Founder</h2>

          <p>
            The Technology Joint is led by Israel Alabi, an SEO strategist and
            technology writer passionate about helping businesses grow through
            search while making technology easier for everyday users.
          </p>

          <a
            href="mailto:israel.alabi.seo@gmail.com"
            class="contact-button"
          >
            Contact the Founder
          </a>

        </div>

      </div>

    </section>

  </main>

  <Footer />

</BaseLayout>

<style>

.about-section{

padding:5rem 0;

}

.about-section.alt{

background:#f8fafc;

}

.content{

max-width:760px;

margin:auto;

}

.content h2{

margin-bottom:1.5rem;

}

.content p{

line-height:1.9;

margin-bottom:1.5rem;

}

.grid{

display:grid;

grid-template-columns:repeat(auto-fit,minmax(280px,1fr));

gap:2rem;

}

.card{

padding:2rem;

background:white;

border:1px solid var(--color-border);

border-radius:18px;

}

.card h3{

margin-bottom:1rem;

}

.card ul{

padding-left:1.2rem;

line-height:2;

}

.founder-box{

max-width:760px;

margin:auto;

text-align:center;

}

.contact-button{

display:inline-block;

margin-top:2rem;

padding:1rem 2rem;

background:var(--color-primary);

color:white;

border-radius:999px;

text-decoration:none;

font-weight:700;

transition:.25s;

}

.contact-button:hover{

opacity:.9;

transform:translateY(-2px);

}

</style>