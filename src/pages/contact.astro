---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/layouts/Header.astro";
import Footer from "../components/layouts/Footer.astro";
import PageHero from "../components/layouts/PageHero.astro";
import { site } from "../data/site";
---

<BaseLayout
    title="Contact | The Technology Joint"
    description="Get in touch with The Technology Joint."
>
    <Header />

    <main>
        <PageHero
            title="Let's Build Something Great Together"
            description="Whether you need SEO consulting, content strategy, technical guidance or simply want to connect, we'd love to hear from you."
        />

        <section class="contact-section">
            <div class="container">
                <div class="contact-grid">
                    <div class="contact-info">
                        <h2>Get in Touch</h2>

                        <p>
                            The Technology Joint works with businesses,
                            startups, creators and organizations looking to
                            improve their digital presence through strategic SEO
                            and high-quality technology content.
                        </p>

                        <div class="info-card">
                            <h3>Email</h3>

                            <p>
                                <a href={`mailto:${site.email}`}>
                                    {site.email}
                                </a>
                            </p>
                        </div>

                        <div class="info-card">
                            <h3>Typical Response Time</h3>

                            <p>Within 24–48 hours.</p>
                        </div>
                    </div>

                    <div class="contact-form">
                        <form>
                            <label for="name">Name</label>

                            <input
                                id="name"
                                type="text"
                                placeholder="Your name"
                            />

                            <label for="email">Email</label>

                            <input
                                id="email"
                                type="email"
                                placeholder="you@example.com"
                            />

                            <label for="subject">Subject</label>

                            <input
                                id="subject"
                                type="text"
                                placeholder="Project enquiry"
                            />

                            <label for="message">Message</label>

                            <textarea
                                id="message"
                                rows="7"
                                placeholder="Tell us about your project..."
                            ></textarea>

                            <button type="submit"> Send Message </button>
                        </form>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <Footer />
</BaseLayout>

<style>
    .contact-section {
        padding: 5rem 0;
    }

    .contact-grid {
        display: grid;

        grid-template-columns: 1fr 1fr;

        gap: 4rem;

        align-items: start;
    }

    .contact-info h2 {
        margin-bottom: 1rem;
    }

    .contact-info p {
        line-height: 1.8;

        margin-bottom: 2rem;
    }

    .info-card {
        padding: 1.5rem;

        border: 1px solid var(--color-border);

        border-radius: 16px;

        margin-bottom: 1.5rem;
    }

    .info-card h3 {
        margin-bottom: 0.5rem;
    }

    .info-card a {
        text-decoration: none;

        color: var(--color-primary);

        font-weight: 600;
    }

    form {
        display: flex;

        flex-direction: column;

        gap: 1rem;
    }

    label {
        font-weight: 600;
    }

    input,
    textarea {
        padding: 1rem;

        border: 1px solid var(--color-border);

        border-radius: 12px;

        font: inherit;
    }

    input:focus,
    textarea:focus {
        outline: none;

        border-color: var(--color-primary);
    }

    button {
        padding: 1rem;

        border: none;

        border-radius: 999px;

        background: var(--color-primary);

        color: white;

        font-weight: 700;

        cursor: pointer;

        transition: 0.25s;
    }

    button:hover {
        opacity: 0.9;

        transform: translateY(-2px);
    }

    @media (max-width: 900px) {
        .contact-grid {
            grid-template-columns: 1fr;
        }
    }
</style>
